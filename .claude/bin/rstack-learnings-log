#!/usr/bin/env bash
# rstack-learnings-log — append a learning to the project learnings file
#
# Usage:
#   rstack-learnings-log '{"skill":"investigate","type":"pitfall","key":"n-plus-one",
#     "insight":"Missing index on user_id caused 2s queries","confidence":9,
#     "source":"observed","files":["src/models/user.py"]}'
#
# Types: pattern | pitfall | preference | architecture | tool
# Sources: observed | user-stated | inferred
# Confidence: 1-10
#
# Storage: ~/.rstack/projects/$SLUG/learnings.jsonl (append-only)
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/rstack-slug" 2>/dev/null)" 2>/dev/null || SLUG="unknown"

RSTACK_HOME="${RSTACK_HOME:-$HOME/.rstack}"
mkdir -p "$RSTACK_HOME/projects/$SLUG"

INPUT="${1:-}"
[ -z "$INPUT" ] && { echo "Usage: rstack-learnings-log '<json>'" >&2; exit 1; }

# Validate JSON
if ! python3 -c "import json,sys; json.loads(sys.argv[1])" "$INPUT" 2>/dev/null; then
  echo "rstack-learnings-log: invalid JSON, skipping" >&2
  exit 1
fi

# Inject timestamp if not present
TS=$(date -u +%Y-%m-%dT%H:%M:%SZ)
FINAL=$(python3 -c "
import json, sys
j = json.loads(sys.argv[1])
if 'ts' not in j:
    j['ts'] = sys.argv[2]
print(json.dumps(j))
" "$INPUT" "$TS" 2>/dev/null) || FINAL="$INPUT"

echo "$FINAL" >> "$RSTACK_HOME/projects/$SLUG/learnings.jsonl"
