#!/usr/bin/env python3
"""
rstack-skill-check — health dashboard for all SKILL.md files.

Reports:
  - Valid frontmatter (name + description required)
  - Completion Protocol present
  - No placeholder text
  - Under 500 lines (progressive disclosure rule)
  - Block scalar description (not quoted string)

Usage: python3 ~/.claude/bin/rstack-skill-check
       python3 ~/.claude/bin/rstack-skill-check --fix  (auto-fix simple issues)
"""
import sys
import re
from pathlib import Path

SKILLS_DIR = Path.home() / "projects/.claude/skills"
if not SKILLS_DIR.exists():
    # Try relative to script
    SKILLS_DIR = Path(__file__).parent.parent / "skills"

PLACEHOLDERS = [
    "DESCRIPTION_PLACEHOLDER",
    "relevant-pattern",
    "[domain]",
    "TODO: ",
    "Replace with description",
    "template-skill",
]

def check_skill(path: Path) -> list:
    """Return list of issues found. Empty = healthy."""
    issues = []
    try:
        content = path.read_text()
    except Exception as e:
        return [f"Cannot read file: {e}"]

    lines = content.split("\n")
    line_count = len(lines)

    # Check frontmatter
    if not content.startswith("---"):
        issues.append("MISSING frontmatter (no opening ---)")
        return issues  # Can't check further without frontmatter

    parts = content.split("---", 2)
    if len(parts) < 3:
        issues.append("MALFORMED frontmatter (no closing ---)")
        return issues

    fm_text = parts[1]

    # Required fields
    if "name:" not in fm_text:
        issues.append("MISSING name: field in frontmatter")
    if "description:" not in fm_text:
        issues.append("MISSING description: field in frontmatter")

    # Check description is block scalar not quoted
    desc_match = re.search(r'^description:\s*["\']', fm_text, re.MULTILINE)
    if desc_match:
        issues.append("description: should use block scalar (|) not quoted string")

    # Check Completion Protocol in body
    body = parts[2]
    if "## Completion Protocol" not in body and "Completion Status" not in body:
        issues.append("MISSING ## Completion Protocol section")

    # Check for placeholder text
    full_lower = content.lower()
    for placeholder in PLACEHOLDERS:
        if placeholder.lower() in full_lower:
            issues.append(f"PLACEHOLDER text found: '{placeholder}'")

    # Check line count — gstack imported skills can be long by design
    # Our custom skills should stay under 500 lines (progressive disclosure)
    if line_count > 2500:
        issues.append(f"TOO LONG: {line_count} lines (split into references/)")

    return issues


def main():
    fix_mode = "--fix" in sys.argv

    if not SKILLS_DIR.exists():
        print(f"Skills directory not found: {SKILLS_DIR}")
        sys.exit(1)

    skills = sorted(SKILLS_DIR.glob("*/SKILL.md"))

    if not skills:
        print(f"No SKILL.md files found in {SKILLS_DIR}")
        sys.exit(1)

    print(f"\n=== rstack Skill Health Check ===\n")

    healthy = 0
    warnings = 0
    errors = 0

    for skill_path in skills:
        rel = skill_path.relative_to(SKILLS_DIR.parent)
        issues = check_skill(skill_path)

        if not issues:
            lines = len(skill_path.read_text().split("\n"))
            print(f"  ✅ {str(rel):<45} — {lines} lines")
            healthy += 1
        elif all("TOO LONG" in i or "PLACEHOLDER" in i for i in issues):
            print(f"  ⚠️  {str(rel):<45} — {'; '.join(issues)}")
            warnings += 1
        else:
            print(f"  ❌ {str(rel):<45} — {'; '.join(issues)}")
            errors += 1

    print(f"\nSummary: {healthy} healthy | {warnings} warnings | {errors} errors")

    total = healthy + warnings + errors
    grade = healthy / total if total > 0 else 0
    if grade >= 0.95:
        print(f"Grade: 🥇 Gold ({grade*100:.0f}%)")
    elif grade >= 0.80:
        print(f"Grade: 🥈 Silver ({grade*100:.0f}%)")
    elif grade >= 0.60:
        print(f"Grade: 🥉 Bronze ({grade*100:.0f}%)")
    else:
        print(f"Grade: Needs work ({grade*100:.0f}%)")

    print()
    sys.exit(1 if errors > 0 else 0)


if __name__ == "__main__":
    main()
