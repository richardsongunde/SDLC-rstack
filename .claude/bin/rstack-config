#!/usr/bin/env bash
# rstack-config — read/write ~/.rstack/config.yaml
#
# Usage:
#   rstack-config get <key>          — read a config value
#   rstack-config set <key> <value>  — write a config value
#   rstack-config list               — show all config
#
# Config file: ~/.rstack/config.yaml
set -euo pipefail

STATE_DIR="${RSTACK_STATE_DIR:-$HOME/.rstack}"
CONFIG_FILE="$STATE_DIR/config.yaml"

CONFIG_HEADER='# rstack configuration — Richardson Gunde AI workspace
# Edit freely. Changes take effect on next skill run.
#
# ─── Behavior ────────────────────────────────────────────────────────
# proactive: true           # Auto-suggest skills when your request matches one.
#                           # Set to false to only run skills you invoke explicitly.
#
# repo_mode: ""             # Override auto-detection: solo | collaborative
#                           # solo = you own everything, fix proactively
#                           # collaborative = flag issues, don't fix (others may own it)
#
# ─── Learnings ───────────────────────────────────────────────────────
# cross_project_learnings: false  # Search learnings from other projects on this machine
#
# ─── Reviews ─────────────────────────────────────────────────────────
# require_review_before_ship: true  # Block /ship if /code-review-pr not run on branch
#
# ─── Analytics ───────────────────────────────────────────────────────
# analytics: local          # off | local
#                           #   off   — no tracking at all
#                           #   local — write to ~/.rstack/analytics/ only
'

mkdir -p "$STATE_DIR"

cmd="${1:-}"
key="${2:-}"
value="${3:-}"

case "$cmd" in
  get)
    [ -z "$key" ] && { echo "Usage: rstack-config get <key>" >&2; exit 1; }
    [ ! -f "$CONFIG_FILE" ] && exit 0
    # Parse YAML: extract value for key (simple key: value format)
    grep -E "^${key}:" "$CONFIG_FILE" 2>/dev/null | head -1 | sed 's/^[^:]*:[[:space:]]*//' | tr -d '"' || true
    ;;

  set)
    [ -z "$key" ] || [ -z "$value" ] && { echo "Usage: rstack-config set <key> <value>" >&2; exit 1; }
    # Write config header if file doesn't exist
    [ ! -f "$CONFIG_FILE" ] && printf '%s' "$CONFIG_HEADER" > "$CONFIG_FILE"
    # Update or append
    if grep -q "^${key}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i.bak "s|^${key}:.*|${key}: ${value}|" "$CONFIG_FILE" && rm -f "${CONFIG_FILE}.bak"
    else
      echo "${key}: ${value}" >> "$CONFIG_FILE"
    fi
    ;;

  list)
    [ ! -f "$CONFIG_FILE" ] && { echo "(no config yet — run 'rstack-config set <key> <value>')"; exit 0; }
    grep -v "^#" "$CONFIG_FILE" | grep -v "^$" || echo "(empty config)"
    ;;

  *)
    echo "Usage: rstack-config <get|set|list> [key] [value]" >&2
    exit 1
    ;;
esac
