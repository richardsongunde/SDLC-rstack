#!/usr/bin/env bash
# rstack-repo-mode — detect solo vs collaborative repo mode
# Usage: source <(rstack-repo-mode)  → sets REPO_MODE variable
# Or:    rstack-repo-mode            → prints REPO_MODE=... line
#
# Detection: if top author has >= 80% of commits in last 90 days → solo
#            otherwise → collaborative
#
# Override: rstack-config set repo_mode solo|collaborative
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

validate_mode() {
  case "$1" in solo|collaborative|unknown) echo "$1" ;; *) echo "unknown" ;; esac
}

# Config override takes precedence
OVERRIDE=$("$SCRIPT_DIR/rstack-config" get repo_mode 2>/dev/null || true)
if [ -n "$OVERRIDE" ]; then
  MODE=$(validate_mode "$OVERRIDE")
  echo "REPO_MODE=$MODE"
  exit 0
fi

# Auto-detect from git history (90-day window)
TOTAL=$(git log --oneline --since="90 days ago" 2>/dev/null | wc -l | tr -d ' ')

if [ "$TOTAL" -lt 10 ]; then
  # Too few commits — can't tell, assume unknown
  echo "REPO_MODE=unknown"
  exit 0
fi

# Find top author commit count
TOP=$(git log --since="90 days ago" --format="%ae" 2>/dev/null | sort | uniq -c | sort -rn | head -1 | awk '{print $1}')
TOP="${TOP:-0}"

# Calculate percentage (integer math)
if [ "$TOTAL" -gt 0 ]; then
  PCT=$(( TOP * 100 / TOTAL ))
else
  PCT=0
fi

if [ "$PCT" -ge 80 ]; then
  echo "REPO_MODE=solo"
else
  echo "REPO_MODE=collaborative"
fi
