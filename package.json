{
  "name": "rstack-agents",
  "version": "1.0.0",
  "description": "Production-ready agentic SDLC framework for Pi and coding agents — orchestrator, builder/validator teams, lifecycle state, and specialist reuse",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "rstack-agents": "bin/rstack-agents.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "validate": "node src/commands/validate.js",
    "lint": "eslint src/ bin/ tests/",
    "sync:templates": "node scripts/sync-templates.js",
    "prepublishOnly": "npm test"
  },
  "keywords": ["pi-package", "pi", "claude-code", "claude", "ai-agents", "llm", "automation", "sdlc", "agentic-sdlc"],
  "author": "Richardson Gunde",
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "files": ["bin/", "src/", "extensions/", "docs/public/", "README.md", "CHANGELOG.md"],
  "pi": {
    "extensions": ["./extensions/rstack-sdlc.ts"]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/richardsongunde/rstack-agents"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "fs-extra": "^11.2.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
